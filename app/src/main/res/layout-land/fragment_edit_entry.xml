<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- TOOLBAR -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/button_green"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:title="Edit Entry"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- VERTICAL GUIDELINE at 65% -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.65" />

    <!-- VISUAL DIVIDER -->
    <View
        android:id="@+id/divider"
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:background="@android:color/darker_gray"
        android:alpha="0.2"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/guideline" />

    <!-- ===== LEFT PANEL ===== -->

    <!-- EMOTION LABEL -->
    <TextView
        android:id="@+id/labelEmotion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="12dp"
        android:text="How are you feeling?"
        android:textStyle="bold"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guideline" />

    <!-- EMOTION ICON ROW -->
    <LinearLayout
        android:id="@+id/emotionRow"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginTop="8dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="12dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/labelEmotion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guideline">

        <ImageView
            android:id="@+id/editHappyIcon"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:background="@drawable/bg_emotion_ripple"
            android:src="@drawable/slightly_happy"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/cd_happy" />

        <ImageView
            android:id="@+id/editSadIcon"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:background="@drawable/bg_emotion_ripple"
            android:src="@drawable/sad"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/cd_sad" />

        <ImageView
            android:id="@+id/editPressuredIcon"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:background="@drawable/bg_emotion_ripple"
            android:src="@drawable/scrunched_eyes"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/cd_pressured" />

        <ImageView
            android:id="@+id/editAngryIcon"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:background="@drawable/bg_emotion_ripple"
            android:src="@drawable/rage"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/cd_angry" />
    </LinearLayout>

    <!-- DESCRIPTION LABEL -->
    <TextView
        android:id="@+id/labelDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="12dp"
        android:text="Description"
        android:textStyle="bold"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/emotionRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guideline" />

    <!-- DESCRIPTION EDIT TEXT — fills remaining left panel height -->
    <EditText
        android:id="@+id/editDescription"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="16dp"
        android:gravity="top"
        android:inputType="textMultiLine"
        android:hint="Describe your feeling..."
        android:textSize="16sp"
        android:lineSpacingMultiplier="1.4"
        android:background="@android:drawable/edit_text"
        app:layout_constraintTop_toBottomOf="@id/labelDescription"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guideline" />

    <!-- ===== RIGHT PANEL ===== -->

    <!-- SAVE BUTTON — vertically centered in right panel -->
    <Button
        android:id="@+id/btnSave"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="20dp"
        android:text="Save Changes"
        android:textColor="@android:color/white"
        android:backgroundTint="@color/button_green"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/guideline"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>