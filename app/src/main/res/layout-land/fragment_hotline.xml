<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    tools:context=".ui.hotline.HotlineFragment">

    <!-- ─────────────────────────────────────────────
         Guidelines
         ───────────────────────────────────────────── -->

    <!-- Splits screen into left (0–38 %) and right (38–100 %) panels -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineVerticalPanelSplit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.38" />

    <!-- Horizontal rails for the left panel content -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineTopRail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.05" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineBottomRail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.95" />

    <!-- Left-panel inner side rails (adds breathing room) -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineLeftInner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.03" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineLeftOuter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.35" />


    <!-- ─────────────────────────────────────────────
         LEFT PANEL
         ───────────────────────────────────────────── -->

    <!-- Header card — compact height for landscape -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardUseCompatPadding="true"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#F4FCD9"
        app:layout_constraintTop_toBottomOf="@id/guidelineTopRail"
        app:layout_constraintStart_toStartOf="@id/guidelineLeftInner"
        app:layout_constraintEnd_toStartOf="@id/guidelineLeftOuter"
        app:layout_constraintBottom_toTopOf="@id/textView1"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp">

            <ImageView
                android:id="@+id/imageView"
                android:layout_width="56dp"
                android:layout_height="match_parent"
                android:scaleType="centerInside"
                android:src="@drawable/hotline"
                android:contentDescription="@string/cd_hotline_header" />

            <TextView
                android:id="@+id/textWelcomeUser"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/hotline_header"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Caption -->
    <TextView
        android:id="@+id/textView1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/hotline_caption"
        android:textSize="12sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/cardView"
        app:layout_constraintStart_toStartOf="@id/guidelineLeftInner"
        app:layout_constraintEnd_toStartOf="@id/guidelineLeftOuter"
        app:layout_constraintBottom_toBottomOf="@id/guidelineBottomRail" />


    <!-- ─────────────────────────────────────────────
         VERTICAL DIVIDER
         ───────────────────────────────────────────── -->

    <View
        android:id="@+id/divider"
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:background="#CCCCCC"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/guidelineVerticalPanelSplit" />


    <!-- ─────────────────────────────────────────────
         RIGHT PANEL — hotline list
         ───────────────────────────────────────────── -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerHotlines"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="15dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/divider"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>