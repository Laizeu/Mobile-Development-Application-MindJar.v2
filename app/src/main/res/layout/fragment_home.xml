<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    tools:context=".ui.home.HomeFragment">

<androidx.core.widget.NestedScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/color_background"
    tools:context=".ui.home.HomeFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Guidelines -->
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/verticalConstraint1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.10"/>

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/verticalConstraint2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.90"/>

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/horizontalConstraint1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.05" />

        <!-- Header card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardUseCompatPadding="true"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#F4FCD9"
            app:layout_constraintTop_toTopOf="@id/horizontalConstraint1"
            app:layout_constraintStart_toStartOf="@id/verticalConstraint1"
            app:layout_constraintEnd_toStartOf="@id/verticalConstraint2">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/imageView"
                    android:layout_width="93dp"
                    android:layout_height="match_parent"
                    android:scaleType="centerInside"
                    android:src="@drawable/handshake"
                    android:contentDescription="@string/cd_handshake"/>

                <TextView
                    android:id="@+id/textWelcomeUser"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/home_welcome_user"
                    android:textSize="30sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/textView9"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/home_feeling_question"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/cardView"
            app:layout_constraintStart_toStartOf="@id/verticalConstraint1"
            app:layout_constraintEnd_toStartOf="@id/verticalConstraint2" />

        <!-- Emotions row -->
        <LinearLayout
            android:id="@+id/linearLayout"
            android:layout_width="0dp"
            android:layout_height="84dp"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/textView9"
            app:layout_constraintStart_toStartOf="@id/verticalConstraint1"
            app:layout_constraintEnd_toStartOf="@id/verticalConstraint2">

            <ImageView
                android:background="@drawable/bg_emotion_ripple"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:id="@+id/happyIcon"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:scaleType="centerInside"
                android:src="@drawable/slightly_happy"
                android:contentDescription="@string/cd_happy"/>

            <ImageView
                android:background="@drawable/bg_emotion_ripple"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:id="@+id/sadIcon"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:scaleType="centerInside"
                android:src="@drawable/sad"
                android:contentDescription="@string/cd_sad"/>

            <ImageView
                android:background="@drawable/bg_emotion_ripple"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:id="@+id/pressuredIcon"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:scaleType="centerInside"
                android:src="@drawable/scrunched_eyes"
                android:contentDescription="@string/cd_pressured"/>

            <ImageView
                android:background="@drawable/bg_emotion_ripple"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:id="@+id/angryIcon"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:scaleType="centerInside"
                android:src="@drawable/rage"
                android:contentDescription="@string/cd_angry"/>
        </LinearLayout>

        <!-- Labels row (aligned via weights) -->
        <LinearLayout
            android:id="@+id/labelsRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/linearLayout"
            app:layout_constraintStart_toStartOf="@id/verticalConstraint1"
            app:layout_constraintEnd_toStartOf="@id/verticalConstraint2">

            <TextView
                android:id="@+id/textHappy"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/label_happy"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/textSad"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/label_sad"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/textPressured"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/label_pressured"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/textAngry"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/label_angry"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <TextView
            android:id="@+id/textView10"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/home_add_your_feelings"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/labelsRow"
            app:layout_constraintStart_toStartOf="@id/verticalConstraint1"
            app:layout_constraintEnd_toStartOf="@id/verticalConstraint2" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/textInputLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:boxStrokeColor="@color/black"
            app:boxBackgroundMode="outline"
            app:layout_constraintTop_toBottomOf="@id/textView10"
            app:layout_constraintStart_toStartOf="@id/verticalConstraint1"
            app:layout_constraintEnd_toStartOf="@id/verticalConstraint2">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputFeeling"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:gravity="top|start"
                android:hint="@string/home_feeling_hint"
                android:inputType="textMultiLine"
                android:minLines="4" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:id="@+id/attachmentsRow"
            android:layout_width="wrap_content"
            android:layout_height="20dp"
            android:layout_marginTop="8dp"
            android:gravity="end|center_vertical"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/textInputLayout"
            app:layout_constraintEnd_toStartOf="@id/verticalConstraint2"
            app:layout_constraintStart_toStartOf="@id/verticalConstraint1"/>

        <Button
            android:id="@+id/button"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text="@string/home_send"
            android:backgroundTint="@color/button_green"
            app:layout_constraintTop_toBottomOf="@id/attachmentsRow"
            app:layout_constraintStart_toStartOf="@id/verticalConstraint1"
            app:layout_constraintEnd_toStartOf="@id/verticalConstraint2" />

        <ImageView
            android:id="@+id/imageView10"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/sent"
            android:contentDescription="@string/cd_sent"
            app:layout_constraintTop_toTopOf="@id/button"
            app:layout_constraintBottom_toBottomOf="@id/button"
            app:layout_constraintEnd_toEndOf="@id/button" />



    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.core.widget.NestedScrollView>
    <!-- Tab strip with person icon — tap to open/close the slide menu -->
    <LinearLayout
        android:id="@+id/menuTabHandle"
        android:layout_width="28dp"
        android:layout_height="64dp"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="100dp"
        android:background="@drawable/tab_handle_shape"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:elevation="6dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/menu"
            android:contentDescription="Account menu" />

    </LinearLayout>
    <!-- Slide-out panel — hidden by default, animates in from left -->
    <LinearLayout
        android:id="@+id/slideMenuPanel"
        android:layout_width="170dp"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="94dp"
        android:layout_marginStart="28dp"
        android:orientation="vertical"
        android:background="@drawable/panel_background"
        android:elevation="10dp"
        android:paddingVertical="4dp"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/menuProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp"
            android:text="My Profile"
            android:drawableStart="@drawable/ic_person"
            android:drawablePadding="10dp"
            android:textSize="14sp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical" />

        <TextView
            android:id="@+id/menuSignOut"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp"
            android:text="Log Out"
            android:drawableStart="@drawable/ic_logout"
            android:drawablePadding="10dp"
            android:textSize="14sp"
            android:textColor="@color/logout"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical" />

    </LinearLayout>

</FrameLayout>

